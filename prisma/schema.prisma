generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  phone        String?
  organization String?
  role         String         @default("USER") // USER | ADMIN
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  registrations Registration[]
  submissions   Submission[]
  bookings      HotelBooking[]
  ownedMeetings Meeting[]      @relation("MeetingOwner")
  staffMeetings MeetingStaff[]
  speakers      Speaker[]
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// 全局站点兜底配置（当会议未单独配置时使用）
model SiteConfig {
  id            Int      @id @default(1)
  confName      String   @default("")
  confDate      String   @default("")
  confLocation  String   @default("")
  logoUrl       String?
  heroImageUrl  String?
  welcomeHtml   String   @default("")
  liveUrl       String?
  contactHtml   String   @default("")
  venueName     String   @default("")
  venueAddress  String   @default("")
  venueLng      String   @default("")
  venueLat      String   @default("")
  footerHtml    String   @default("")
  updatedAt     DateTime @updatedAt
}

model Page {
  id          String   @id @default(cuid())
  meetingId   String   @default("default-meeting")
  slug        String
  title       String
  contentHtml String   @default("")
  updatedAt   DateTime @updatedAt
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, slug])
  @@index([meetingId])
}

model Notice {
  id          String   @id @default(cuid())
  meetingId   String   @default("default-meeting")
  title       String
  contentHtml String   @default("")
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model Meeting {
  id                String          @id @default(cuid())
  title             String
  description       String          @default("")
  location          String          @default("")
  startDate         String          @default("")
  endDate           String          @default("")
  isDefault         Boolean         @default(false)
  requireApproval   Boolean         @default(false)
  registrationLimit Int?
  opensAt           String?
  closesAt          String?
  // 会议级站点配置
  confDate          String          @default("")
  welcomeHtml       String          @default("")
  footerHtml        String          @default("")
  contactHtml       String          @default("")
  logoUrl           String?
  heroImageUrl      String?
  liveUrl           String?
  homeGridColumns   Int             @default(4)
  ownerId           String?
  owner             User?           @relation("MeetingOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  registrations    Registration[]
  bookings         HotelBooking[]
  submissions      Submission[]
  guests           Guest[]
  channels         Channel[]
  badgeTemplate    BadgeTemplate?
  staff            MeetingStaff[]
  notices          Notice[]
  pages            Page[]
  speakers         Speaker[]
  sessions         Session[]
  hotels           Hotel[]
  albums           Album[]
  homeGridItems    HomeGridItem[]
  liveStreams      LiveStream[]

  @@index([isDefault])
}

model LiveStream {
  id          String  @id @default(cuid())
  meetingId   String
  name        String
  url         String
  coverImage  String?
  description String  @default("")
  time        String  @default("")
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meeting     Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, sortOrder])
}

model HomeGridItem {
  id              String  @id @default(cuid())
  meetingId       String
  title           String
  href            String
  icon            String  @default("file")
  size            String  @default("SMALL") // SMALL | WIDE | TALL | LARGE
  backgroundImage String?
  sortOrder       Int     @default(0)
  isVisible       Boolean @default(true)
  meeting         Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, sortOrder])
}

model RegistrationType {
  id            String         @id @default(cuid())
  name          String
  fee           Int            @default(0)
  description   String         @default("")
  registrations Registration[]
}

model Registration {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  meetingId    String
  meeting      Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  typeId       String
  type         RegistrationType        @relation(fields: [typeId], references: [id], onDelete: Restrict)
  channelId    String?
  fullName     String
  organization String                  @default("")
  title        String                  @default("")
  phone        String                  @default("")
  status       String                  @default("PENDING") // PENDING | APPROVED | REJECTED
  // 签到凭证与状态
  token        String                  @unique @default(uuid())
  checkedIn    Boolean                 @default(false)
  checkedInAt  DateTime?
  checkinLogs  CheckinLog[]
  createdAt    DateTime                @default(now())
  reception    RegistrationReception?

  @@unique([userId, meetingId])
  @@index([meetingId])
  @@index([channelId])
}

model CheckinLog {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  checkedAt      DateTime     @default(now())
  byUserId       String?      // 管理员操作时记录其 userId，自助签到为空
  method         String       @default("SCAN") // SCAN | MANUAL | SELF

  @@index([registrationId])
  @@index([checkedAt])
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title     String
  authors   String
  abstract  String
  fileUrl   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([meetingId])
}

model Speaker {
  id           String           @id @default(cuid())
  meetingId    String           @default("default-meeting")
  name         String
  title        String           @default("")
  organization String           @default("")
  bio          String           @default("")
  photoUrl     String?
  token        String?          @unique @default(uuid())
  invitedAt    DateTime?
  confirmed    Boolean          @default(false)
  confirmedAt  DateTime?
  userId       String?
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessions     SessionSpeaker[]
  materials    SpeakerMaterial[]
  meeting      Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([userId])
}

model Session {
  id        String            @id @default(cuid())
  meetingId String            @default("default-meeting")
  day       String // 日期 YYYY-MM-DD
  startTime String
  endTime   String
  room      String            @default("")
  title     String
  speakers  SessionSpeaker[]
  materials SpeakerMaterial[]
  meeting   Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model SessionSpeaker {
  sessionId String
  speakerId String
  role      String  @default("SPEAKER") // SPEAKER | MODERATOR
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker   Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  @@id([sessionId, speakerId, role])
}

model SpeakerMaterial {
  id         String   @id @default(cuid())
  speakerId  String
  sessionId  String
  fileUrl    String
  fileName   String
  fileSize   Int
  uploadedAt DateTime @default(now())
  speaker    Speaker  @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([speakerId])
  @@index([sessionId])
}

model Hotel {
  id          String         @id @default(cuid())
  meetingId   String         @default("default-meeting")
  name        String
  description String         @default("")
  price       Int            @default(0)
  address     String         @default("")
  imageUrl    String?
  distance    String         @default("")
  bookings    HotelBooking[]
  meeting     Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model HotelBooking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  checkIn   String
  checkOut  String
  rooms     Int      @default(1)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([meetingId])
}

model Album {
  id        String  @id @default(cuid())
  meetingId String  @default("default-meeting")
  title     String
  date      String  @default("")
  coverUrl  String?
  photos    Photo[]
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model Photo {
  id        String   @id @default(cuid())
  albumId   String
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url       String
  caption   String   @default("")
  createdAt DateTime @default(now())
}

model Guest {
  id          String          @id @default(cuid())
  meetingId   String
  meeting     Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  email       String?
  company     String          @default("")
  title       String          @default("")
  level       String          @default("NORMAL") // VIP | NORMAL | MEDIA
  avatarUrl   String?
  bio         String          @default("")
  token       String          @unique @default(uuid())
  confirmed   Boolean         @default(false)
  confirmedAt DateTime?
  note        String          @default("")
  seatInfo    String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  reception   GuestReception?

  @@index([meetingId])
  @@index([level])
}

model GuestReception {
  id              String   @id @default(cuid())
  guestId         String   @unique
  guest           Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  arriveMode      String   @default("") // 航班/高铁/自驾
  arriveNo        String   @default("")
  arriveTime      String   @default("")
  arrivePlace     String   @default("")
  departMode      String   @default("")
  departNo        String   @default("")
  departTime      String   @default("")
  hotelName       String   @default("")
  hotelRoom       String   @default("")
  hotelCheckIn    String   @default("")
  hotelCheckOut   String   @default("")
  carPlate        String   @default("")
  carDriver       String   @default("")
  carDriverPhone  String   @default("")
  carContact      String   @default("")
  remark          String   @default("")
  updatedAt       DateTime @updatedAt
}

model RegistrationReception {
  id              String       @id @default(cuid())
  registrationId  String       @unique
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  arriveMode      String       @default("") // 航班/高铁/自驾
  arriveNo        String       @default("")
  arriveTime      String       @default("")
  arrivePlace     String       @default("")
  departMode      String       @default("")
  departNo        String       @default("")
  departTime      String       @default("")
  hotelName       String       @default("")
  hotelRoom       String       @default("")
  hotelCheckIn    String       @default("")
  hotelCheckOut   String       @default("")
  carPlate        String       @default("")
  carDriver       String       @default("")
  carDriverPhone  String       @default("")
  carContact      String       @default("")
  remark          String       @default("")
  updatedAt       DateTime     @updatedAt
}

model BadgeTemplate {
  id                String   @id @default(cuid())
  meetingId         String   @unique
  meeting           Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  pageWidthMm       Int      @default(86)
  pageHeightMm      Int      @default(147)
  bgImageUrl        String?
  labelGapMm        Int      @default(2)
  nameX             Int      @default(43)
  nameY             Int      @default(52)
  nameSize          Int      @default(14)
  titleX            Int      @default(43)
  titleY            Int      @default(40)
  titleSize         Int      @default(14)
  companyX          Int      @default(43)
  companyY          Int      @default(28)
  companySize       Int      @default(14)
  qrX               Int      @default(43)
  qrY               Int      @default(92)
  qrSize            Int      @default(34)
  meetingTitleX     Int      @default(43)
  meetingTitleY     Int      @default(128)
  meetingTitleSize  Int      @default(17)
  updatedAt         DateTime @updatedAt
}

model Channel {
  id        String         @id @default(cuid())
  meetingId String
  meeting   Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  code      String
  name      String
  owner     String         @default("")
  note      String         @default("")
  createdAt DateTime       @default(now())
  visits    ChannelVisit[]

  @@unique([meetingId, code])
  @@index([meetingId])
}

model ChannelVisit {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  ip        String?
  ua        String?
  sessionId String?
  visitedAt DateTime @default(now())

  @@index([channelId])
  @@index([sessionId])
}

model MeetingStaff {
  meetingId String
  userId    String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedAt DateTime @default(now())

  @@id([meetingId, userId])
}
