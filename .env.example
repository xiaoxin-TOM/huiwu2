# 复制为 .env 后按需修改。切勿提交 .env 到 git。

# PostgreSQL 连接串:postgresql://用户:密码@主机:端口/库名
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/huiwu_dev"

# Auth.js 会话签名密钥(生产务必改成随机长串,例如 `openssl rand -base64 32`)
AUTH_SECRET="change-me-in-production"

# Auth.js 公开访问地址。若应用部署在非 localhost 域名(如 http://39.96.221.13:3003),
# 必须设置为实际可访问的完整 URL,否则退出登录等回调可能跳转到 localhost。
# AUTH_URL="http://39.96.221.13:3003"

# 邮件服务配置（用于注册验证码）
EMAIL_USER="wealzeal@126.com"
EMAIL_PASS="HXTaRYzyzbWW8mYT"

# 阿里云 OSS 配置（讲者报告资料上传）
ALIYUN_OSS_REGION="oss-cn-beijing"
ALIYUN_OSS_BUCKET="your-bucket-name"
ALIYUN_OSS_ACCESS_KEY_ID="your-access-key-id"
ALIYUN_OSS_ACCESS_KEY_SECRET="your-access-key-secret"
# 自定义 Endpoint（可选，不填则使用默认公网 Endpoint）
# ALIYUN_OSS_ENDPOINT="https://oss-cn-beijing.aliyuncs.com"
# 返回给前端的公网访问基础 URL（可选，不填则使用 OSS 默认 URL）
# ALIYUN_OSS_PUBLIC_BASE_URL="https://your-bucket-name.oss-cn-beijing.aliyuncs.com"
# 文件访问基础 URL（可选，优先级高于 ALIYUN_OSS_PUBLIC_BASE_URL，可用于 CDN 或自定义域名）
# IMAGE_BASE_URL="https://your-cdn.example.com"

# OSS 通用访问路径（文件在 Bucket 中的前缀，不填则默认为 uploads；仅路径，不要写 http 链接）
OSS_BASE_PATH="uploads"
# OSS 上传者标识（可选，会作为对象元数据写入）
OSS_USER_ID="system"
OSS_USER_NAME="huiwu"
